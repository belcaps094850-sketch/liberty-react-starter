<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
    xmlns="https://jakarta.ee/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
        https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="claims-pu" transaction-type="JTA">
        <jta-data-source>jdbc/claimsDB</jta-data-source>
        <class>com.example.model.Claim</class>
        <properties>
            <!-- Auto-create tables on startup, update on changes -->
            <property name="jakarta.persistence.schema-generation.database.action" value="create" />
            <!-- Show SQL in logs (disable in production) -->
            <property name="eclipselink.logging.level.sql" value="FINE" />
        </properties>
    </persistence-unit>
</persistence>
